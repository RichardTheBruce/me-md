{
  "name": "me.md",
  "version": "0.1.0",
  "description": "A portable digital twin you fill with yourself. A local-LLM orchestrator over your own .md neural net: the package becomes you, the local model is the voice, your .md world is the memory, your MCP servers are the hands. No content rules, routed by your hardware.",
  "type": "module",
  "bin": {
    "me": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/persona/me.md",
    "corpus.config.json",
    "scripts/bootstrap.sh",
    "scripts/bootstrap.ps1",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "me": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "local-llm",
    "digital-twin",
    "orchestrator",
    "mcp",
    "rag",
    "ollama",
    "neural-net"
  ],
  "author": "Richard Wayne (RichardTheBruce)",
  "license": "UNLICENSED",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
