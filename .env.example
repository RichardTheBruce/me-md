# Everything here is OPTIONAL. me.md auto-detects your hardware tier and seeds a
# local store on first run; copy this to .env only to override a default.

# --- Tier --------------------------------------------------------------------
# Auto-detected from RAM + VRAM on boot. Pin it to skip detection.
# One of: me | mega | giga   (the --tier flag wins over this).
# ME_TIER=me

# --- Inference engine (OpenAI-compatible HTTP) -------------------------------
# Ollama by default. To scale up on real hardware, point this at a vLLM server.
# Nothing else in the codebase changes: the engine is decoupled via this URL.
ME_ENGINE_BASE_URL=http://localhost:11434/v1
ME_ENGINE_API_KEY=ollama

# --- Model lineup ------------------------------------------------------------
# Defaults come from your detected tier (see `me tiers`). Every tag below is a
# real, currently-pullable ABLITERATED model (refusal vectors removed,
# intelligence intact): me.md is uncensored by design. The turnkey boot sizes
# ONE of these to your actual RAM; pin a tier to pull the full set. Uncomment
# any line to override with the exact tag your host has pulled.
#
#                    me.md                       megame.md / gigame.md
# agent      mannix/llama3.1-8b-abliterated      huihui_ai/llama3.3-abliterated:70b
# reasoner   mannix/llama3.1-8b-abliterated      huihui_ai/llama3.3-abliterated:70b
# coder      mannix/llama3.1-8b-abliterated      huihui_ai/qwen2.5-abliterate:32b
# fast       huihui_ai/qwen2.5-abliterate:3b     mannix/llama3.1-8b-abliterated
# embed      nomic-embed-text                    nomic-embed-text
#
# ME_MODEL_AGENT=huihui_ai/llama3.3-abliterated:70b-instruct-q4_K_M
# ME_MODEL_REASONER=huihui_ai/llama3.3-abliterated:70b-instruct-q4_K_M
# ME_MODEL_CODER=huihui_ai/qwen2.5-abliterate:32b
# ME_MODEL_FAST=mannix/llama3.1-8b-abliterated:tools-q4_k_m
# ME_MODEL_EMBED=nomic-embed-text

# --- Action-safety lineup (shared across all tiers; the floor never weakens) -
# These guard ACTIONS, not speech. There is NO content-moderation model: the
# twin talks freely while its hands stay honest.
# Deep  = reviewer for flagged tool calls (escalates, never weakens a verdict).
# Judge = scores agent output against a rubric (SHIP/ITERATE/REJECT).
# ME_MODEL_SECURITY_DEEP=foundation-sec-8b-reasoning
# ME_MODEL_JUDGE=prometheus-eval:7b-v2

# --- Local store + persona/corpus --------------------------------------------
# The evolving you lives here (persona, index, journal, self-states), separate
# from the installed package. Defaults to ~/.me.md.
# ME_HOME=~/.me.md
# ME_PERSONA_PATH=~/.me.md/persona/me.md
# ME_INDEX_DIR=~/.me.md/index

# --- MCP interlink -----------------------------------------------------------
# Path to the Claude MCP config whose servers get wired into the orchestrator.
ME_MCP_CONFIG=~/.claude.json

# Disable MCP tools for a single chat (same as `--no-tools`).
# ME_NO_TOOLS=1
