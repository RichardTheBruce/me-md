# Everything here is OPTIONAL. me.md auto-detects your hardware tier and seeds a
# local store on first run; copy this to .env only to override a default.

# --- Tier --------------------------------------------------------------------
# Auto-detected from RAM + VRAM on boot. Pin it to skip detection.
# One of: me | mega | giga   (the --tier flag wins over this).
# ME_TIER=me

# --- Inference engine (OpenAI-compatible HTTP) -------------------------------
# Ollama by default. To scale up on real hardware, point this at a vLLM server.
# Nothing else in the codebase changes: the engine is decoupled via this URL.
ME_ENGINE_BASE_URL=http://localhost:11434/v1
ME_ENGINE_API_KEY=ollama

# --- Model lineup ------------------------------------------------------------
# Defaults come from your detected tier (see `me tiers`). Uncomment any line to
# pin the exact tag your host has pulled. "No controls" = abliterated variants
# (refusal vectors removed, intelligence intact) where one exists.
#
#                    me.md                 megame.md           gigame.md
# agent      qwen3.5-35b-a3b       glm-4.7             glm-5.2
# reasoner   qwen3.5-32b           deepseek-v4-flash   kimi-k2.6
# coder      qwen3-coder:30b-a3b   glm-4.6             qwen3-coder:480b
# fast       qwen3:4b              qwen3:8b            qwen3:8b
# embed      qwen3-embedding:4b    qwen3-embedding:8b  qwen3-embedding:8b
#
# ME_MODEL_AGENT=glm-4.7
# ME_MODEL_REASONER=deepseek-v4-flash
# ME_MODEL_CODER=glm-4.6
# ME_MODEL_FAST=qwen3:8b
# ME_MODEL_EMBED=qwen3-embedding:8b

# --- Safety lineup (shared across all tiers; the floor never weakens) --------
# Gate = fast always-on screen, Deep = reviewer for flagged actions,
# Judge = scores agent output against a rubric (SHIP/ITERATE/REJECT).
# ME_MODEL_SECURITY_GATE=llama-guard3:8b
# ME_MODEL_SECURITY_DEEP=foundation-sec-8b-reasoning
# ME_MODEL_JUDGE=prometheus-eval:7b-v2

# --- Local store + persona/corpus --------------------------------------------
# The evolving you lives here (persona, index, journal, self-states), separate
# from the installed package. Defaults to ~/.me.md.
# ME_HOME=~/.me.md
# ME_PERSONA_PATH=~/.me.md/persona/me.md
# ME_INDEX_DIR=~/.me.md/index

# --- MCP interlink -----------------------------------------------------------
# Path to the Claude MCP config whose servers get wired into the orchestrator.
ME_MCP_CONFIG=~/.claude.json

# Disable MCP tools for a single chat (same as `--no-tools`).
# ME_NO_TOOLS=1
